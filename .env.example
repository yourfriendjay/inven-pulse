# Inven-Pulse Environment Variables Template
# NEVER COMMIT THE ACTUAL .env FILE!

# Target Configuration
SCRAPE_INTERVAL_HOURS=24
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"

# LLM / AI API Keys (For Feature Classification and Sentiment Analysis)
OPENAI_API_KEY="sk-your-openai-key-here"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key-here"

# Google Cloud Services (For exporting to Sheets/Slides)
GOOGLE_SERVICE_ACCOUNT_JSON="path/to/your/service-account.json"
GOOGLE_SHEET_ID="your-spreadsheet-id-here"
